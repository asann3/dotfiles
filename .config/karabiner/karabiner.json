                                "conditions": [
                                    {
                                        "input_sources": [{ "language": "ja" }],
                                        "type": "input_source_if"
                                    },
                                    {
                                        "name": "j_pressed_ja",
                                        "type": "variable_if",
                                        "value": 1
                                    }
                                ],
                                "from": {
                                    "key_code": "j",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    { "key_code": "delete_or_backspace" },
                                    { "key_code": "escape" },
                                    { "key_code": "japanese_eisuu" },
                                    {
                                        "set_variable": {
                                            "name": "j_pressed_ja",
                                            "value": 0
                                        }
                                    }
                                ],
                                "type": "basic"
                            },
                            {
                                "conditions": [
                                    {
                                        "input_sources": [{ "language": "ja" }],
                                        "type": "input_source_if"
                                    },
                                    {
                                        "name": "j_pressed_ja",
                                        "type": "variable_if",
                                        "value": 0
                                    }
                                ],
                                "from": {
                                    "key_code": "j",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "parameters": { "basic.to_delayed_action_delay_milliseconds": 200 },
                                "to": [
                                    {
                                        "set_variable": {
                                            "name": "j_pressed_ja",
                                            "value": 1
                                        }
                                    },
                                    { "key_code": "j" }
                                ],
                                "to_delayed_action": {
                                    "to_if_canceled": [
                                        {
                                            "set_variable": {
                                                "name": "j_pressed_ja",
                                                "value": 0
                                            }
                                        }
                                    ],
                                    "to_if_invoked": [
                                        {
                                            "set_variable": {
                                                "name": "j_pressed_ja",
                                                "value": 0
                                            }
                                        }
                                    ]
                                },
                                "type": "basic"
                            }
                        ]
