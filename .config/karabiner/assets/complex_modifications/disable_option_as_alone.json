{
  "title": "Disable Option alone, keep modifier behavior",
  "rules": [
    {
      "description": "Option alone does nothing (avoid special character input), keep modifier behavior",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "left_option",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to_if_alone": [
            {
              "key_code": "vk_none"
            }
          ],
          "to_if_held_down": [
            {
              "key_code": "left_option"
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "right_option",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to_if_alone": [
            {
              "key_code": "vk_none"
            }
          ],
          "to_if_held_down": [
            {
              "key_code": "right_option"
            }
          ]
        }
      ]
    }
  ]
}
